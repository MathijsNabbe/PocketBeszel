# Server port
PORT=3000

# Beszel hub URL (use Docker service name when running in compose)
BESZEL_URL=http://beszel:8090

# PocketBase JWT bearer token (see README for how to generate)
BESZEL_API_KEY=

# Optional: auto re-authenticate when JWT expires
BESZEL_EMAIL=
BESZEL_PASSWORD=

# Cache refresh interval in milliseconds
REFRESH_INTERVAL=30000
